# ========================================
# Salon Booking AI — Environment Variables
# ========================================
# Copy this file to .env and fill in your values

# --- Server ---
PORT=3000
NODE_ENV=development

# --- PostgreSQL ---
# Option A: Connection string (recommended for cloud DBs like Neon/Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/salon_booking

# Option B: Individual fields (for local PostgreSQL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=salon_booking
# DB_USER=postgres
# DB_PASSWORD=yourpassword

# --- Google Gemini (Free Tier) ---
GEMINI_API_KEY=AIzaSy...

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Salon Config ---
SALON_NAME=Glamour Salon
SALON_OPENING_HOUR=9
SALON_CLOSING_HOUR=19
ADMIN_SECRET=your-admin-secret-key
